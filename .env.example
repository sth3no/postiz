# =============================================================================
# Postiz self-host environment variables
#
# Copy this file as a guide and paste these values into the Portainer stack's
# "Environment variables" section (NOT into git). Anything left blank is
# optional. Required variables are flagged below.
#
# Reference: https://docs.postiz.com/configuration/reference
# =============================================================================

# --- REQUIRED: public URLs the user's browser will hit ----------------------
# Use the exact origin you'll access Postiz on (https in production).
# Example: MAIN_URL=https://postiz.example.com
MAIN_URL=
FRONTEND_URL=
# Backend URL is MAIN_URL + /api
NEXT_PUBLIC_BACKEND_URL=

# --- REQUIRED: secrets ------------------------------------------------------
# Generate fresh values per install. ~48-byte random base64 is fine.
JWT_SECRET=

# Postgres (used by Postiz). Pick any user/db name; password must be strong.
POSTGRES_USER=postiz
POSTGRES_PASSWORD=
POSTGRES_DB=postiz

# Internal Temporal database — leave defaults unless you have a reason
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=

# --- Networking -------------------------------------------------------------
# Bind to loopback when a reverse proxy (Caddy/Traefik/nginx) is in front.
# Use 0.0.0.0 to expose Postiz directly on the public interface (NOT recommended).
POSTIZ_BIND=127.0.0.1
POSTIZ_PORT=4007
TEMPORAL_UI_BIND=127.0.0.1
TEMPORAL_UI_PORT=8080

# Pin the image version (e.g., v2.13.0) or leave as latest.
POSTIZ_VERSION=latest

# --- Optional: registration / email ----------------------------------------
DISABLE_REGISTRATION=false
# If RESEND_API_KEY is set, account activation emails are required.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# --- Optional: object storage (default is local volume) --------------------
STORAGE_PROVIDER=local
# Set STORAGE_PROVIDER=cloudflare and fill these to use Cloudflare R2:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKETNAME=
CLOUDFLARE_BUCKET_URL=
CLOUDFLARE_REGION=auto

# --- Optional: misc ---------------------------------------------------------
OPENAI_API_KEY=
API_LIMIT=30

# --- Optional: Stripe (only needed if you want billing) --------------------
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=

# --- Optional: social platform OAuth credentials ---------------------------
# Add only the ones you actually want to schedule posts for. Each platform's
# OAuth app must include this redirect URI:
#   ${MAIN_URL}/integrations/social/<platform>
X_URL=
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
